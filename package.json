{
  "name": "wembley-downs-div-8-2026",
  "version": "1.0.0",
  "description": "Static single-page app for team player voting, hosted on [Firebase Hosting](https://wembley-downs-div-8-2026.web.app/).",
  "main": "index.js",
  "scripts": {
    "validate": "node tools/ci-validate.js",
    "test": "node tools/ci-validate.js",
    "test:name-match": "node tools/test-name-match.mjs",
    "test:tally": "node tools/test-tally.mjs",
    "test:round-date": "node tools/test-round-date.mjs",
    "test:rules": "npx -y firebase-tools@latest emulators:exec --only firestore --project wembley-downs-rules-test \"node tools/test-firestore-rules.mjs\"",
    "test:browser": "node tools/browser-test.js",
    "test:visual": "node tools/visual-qa.js",
    "test:smoke": "node tools/smoke-fetch.js",
    "test:squadi": "node tools/test-squadi.mjs",
    "sync:squadi": "node tools/squadi-sync.mjs --config squadi-config.json --dry-run",
    "sync:squadi:write": "node tools/squadi-sync.mjs --config squadi-config.json --write",
    "restore:votes": "node tools/restore-votes-from-git.mjs --write-seed",
    "build": "node tools/build-app.mjs",
    "bump": "node tools/bump-version.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KingOTR/wembley-downs-div-8-2026.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/KingOTR/wembley-downs-div-8-2026/issues"
  },
  "homepage": "https://github.com/KingOTR/wembley-downs-div-8-2026#readme",
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "esbuild": "^0.25.0",
    "firebase-admin": "^14.0.0"
  }
}
