rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSuperAdmin() {
      return request.auth != null
        && request.auth.token.email == 'sydneywilliam29@gmail.com';
    }

    function isValidVote() {
      return request.resource.data.keys().hasAll([
          'teamId', 'voterName', 'voterNameKey', 'round', 'picks', 'submittedAt'
        ])
        && request.resource.data.picks is list
        && request.resource.data.picks.size() == 3
        && request.resource.data.voterName is string
        && request.resource.data.voterNameKey is string
        && request.resource.data.voterNameKey.size() > 0
        && request.resource.data.voterNameKey.size() <= 80
        && request.resource.data.voterNameKey.matches('^[a-z0-9-]+$')
        && request.resource.data.round is string;
    }

    /** Doc id t{team}_r{roundKey}_v{voterKey} must match payload voterNameKey + teamId. */
    function voteIdMatchesPayload(voteId, data) {
      return voteId.matches('t[0-9]+_r.+_v.+')
        && voteId.matches('t' + string(data.teamId) + '_r.+_v.+')
        && voteId.matches('.*_v' + data.voterNameKey + '$');
    }

    function isValidCoachVote() {
      return request.resource.data.picks is list
        && request.resource.data.picks.size() == 3
        && request.resource.data.teamId != null
        && request.resource.data.slot != null
        && request.resource.data.round is string;
    }

    /** Doc id c{team}_r{roundKey}_s{slot} must match payload teamId + slot. */
    function coachIdMatchesPayload(coachId, data) {
      return coachId.matches('c[0-9]+_r.+_s[0-9]+')
        && coachId.matches('c' + string(data.teamId) + '_r.+_s.+')
        && coachId.matches('.*_s' + string(data.slot) + '$');
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /votes/{voteId} {
      allow read: if true;
      allow create: if voteIdMatchesPayload(voteId, request.resource.data)
        && isValidVote();
      allow update: if isSuperAdmin()
        || (voteIdMatchesPayload(voteId, request.resource.data)
          && isValidVote()
          && resource.data.voterNameKey == request.resource.data.voterNameKey);
      allow delete: if isSuperAdmin();
    }

    match /coachVotes/{docId} {
      allow read: if true;
      allow create: if coachIdMatchesPayload(docId, request.resource.data)
        && isValidCoachVote();
      allow update: if isSuperAdmin()
        || (coachIdMatchesPayload(docId, request.resource.data)
          && isValidCoachVote()
          && resource.data.slot == request.resource.data.slot);
      allow delete: if isSuperAdmin();
    }

    match /adminLog/{docId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin();
      allow update, delete: if false;
    }
  }
}
